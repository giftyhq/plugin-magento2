{
  "name": "gifty/plugin-magento2",
  "description": "Gifty module for accepting Gifty gift cards in your Magento2 shop.",
  "type": "magento2-module",
  "version": "1.1.0",
  "license": "MIT",
  "require": {
    "php": "~8.2.0||~8.3.0||~8.4.0||~8.5.0",
    "magento/framework": "^103.0",
    "magento/module-quote": "^101.1",
    "magento/module-sales": "^103.0",
    "magento/module-sales-rule": "^101.2",
    "magento/module-store": "^101.1",
    "gifty/gifty-php": "^1.8.0"
  },
  "require-dev": {
    "magento/magento-coding-standard": "^33",
    "phpstan/phpstan": "^1",
    "bitexpert/phpstan-magento": "^0.11.0",
    "phpstan/extension-installer": "^1.4"
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true,
      "magento/composer-dependency-version-audit-plugin": true,
      "phpstan/extension-installer": true
    }
  },
  "repositories": [
    {
      "type": "composer",
      "url": "https://repo.magento.com/"
    }
  ],
  "autoload": {
    "files": [
      "registration.php"
    ],
    "psr-4": {
      "Gifty\\Magento\\": ""
    }
  }
}
